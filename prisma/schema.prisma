generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Auth.js (NextAuth v5) models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Set only for email/password (credentials) accounts; OAuth users won't have one.
  passwordHash  String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// --- App models ---

model Booking {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name      String
  email     String
  phone     String
  service   String
  dob       String
  tob       String
  pob       String
  question  String?

  status    BookingStatus @default(PENDING)
}

model Subscriber {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  email     String   @unique
}

model Product {
  id              String          @id @default(cuid())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  slug            String          @unique
  name            String
  category        ProductCategory @default(CRYSTAL)
  imageUrl        String?         // Cloudinary URL of the product photo
  benefit         String          // short tagline
  longDescription String
  price           Int
  badge           String?         // "Bestseller" | "New" | null
  published       Boolean         @default(true)

  // Optional, mostly crystal-specific attributes
  properties      String[]
  zodiac          String[]
  chakra          String?
  origin          String?
}

model Service {
  id              String          @id @default(cuid())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  slug            String          @unique
  name            String
  shortName       String?
  imageUrl        String?         // Cloudinary URL of the service image
  icon            String?         // legacy emoji fallback
  tagline         String
  description     String
  longDescription String
  price           Int
  duration        String
  includes        String[]
  faqs            Json?    // [{ q, a }] — optional FAQ list
  published       Boolean  @default(true)
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ProductCategory {
  CRYSTAL
  SPELL_KIT
  AFFIRMATION
  GIFT_SET
  OTHER
}

enum Role {
  USER
  ADMIN
  ASTROLOGER
}
